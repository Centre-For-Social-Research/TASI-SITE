NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=noreply@trustandsafetyindia.org
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx
INBOUND_NOTIFICATION_EMAILS=info1@csrindia.org,events@csrindia.org
CLERK_ACCESS_MODE=both
CLERK_ADMIN_EMAILS=saquib@csrindia.org
CLERK_REVIEWER_EMAILS=reviewer1@example.com,reviewer2@example.com
# Optional local override. Leave empty in Vercel to use public/img/tasi-csr-logo.png.
BADGE_LOGO_FILE_PATH=
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-01
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000

# Upstash Redis (rate limiting — optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Razorpay (ticketing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Sentry (error tracking — optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
GEMINI_API_KEY= 

# Azure Communication Services WhatsApp (optional high-priority notification channel)
AZURE_WHATSAPP_ENABLED=false
AZURE_COMMUNICATION_SERVICES_CONNECTION_STRING=
AZURE_WHATSAPP_CHANNEL_REGISTRATION_ID=
AZURE_WHATSAPP_TEMPLATE_LANGUAGE=en_US
AZURE_WHATSAPP_TEMPLATE_CONFIRMED=
AZURE_WHATSAPP_TEMPLATE_CONFIRMED_PARAMS=firstName,eventName
AZURE_WHATSAPP_TEMPLATE_QR_PASS_ISSUED=
AZURE_WHATSAPP_TEMPLATE_QR_PASS_ISSUED_PARAMS=firstName,registrationCode
AZURE_WHATSAPP_HIGH_PRIORITY_TEMPLATES=confirmed,qr_pass_issued
# Optional fallback for non-E.164 local numbers. India numbers are inferred only when country is India.
AZURE_WHATSAPP_DEFAULT_COUNTRY_CODE=
